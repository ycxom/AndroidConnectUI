<Window x:Class="AndroidConnectUI.ResolutionInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置分辨率"
        Height="220"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="请输入分辨率 (例如: 1080x1920)"
                   FontSize="14" Margin="0,0,0,10"/>

        <TextBox x:Name="txtResolution" Grid.Row="1"
                 FontSize="14" Padding="8,6"
                 Background="{StaticResource CardBackgroundBrush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource CardBorderBrush}"
                 BorderThickness="1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="常用分辨率:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="1080x1920" FontSize="11" Padding="8,4" Margin="0,0,5,0"
                    Click="PresetResolution_Click" Tag="1080x1920"
                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="720x1280" FontSize="11" Padding="8,4" Margin="0,0,5,0"
                    Click="PresetResolution_Click" Tag="720x1280"
                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="1440x2560" FontSize="11" Padding="8,4" Margin="0,0,5,0"
                    Click="PresetResolution_Click" Tag="1440x2560"
                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确定" Width="80" Height="32" Margin="0,0,10,0"
                    Click="btnOK_Click"
                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
            <Button Content="取消" Width="80" Height="32"
                    Click="btnCancel_Click"
                    Background="{StaticResource CardBackgroundBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
