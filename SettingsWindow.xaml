<Window x:Class="AndroidConnectUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="380"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="不休眠设置"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <RadioButton x:Name="rbUsbNoSleep" Grid.Row="1" Content="USB 连接不休眠"
                     FontSize="14" Margin="0,0,0,8" GroupName="SleepMode"/>
        <TextBlock Grid.Row="2" Text="设备通过 USB 连接时保持屏幕常亮"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,0,12"/>

        <RadioButton x:Name="rbPowerNoSleep" Grid.Row="3" Content="连接电源不休眠"
                     FontSize="14" Margin="0,0,0,8" GroupName="SleepMode"/>
        <TextBlock Grid.Row="4" Text="设备连接任何电源时保持屏幕常亮"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,0,12"/>

        <RadioButton x:Name="rbDefaultSleep" Grid.Row="5" Content="使用系统默认"
                     FontSize="14" Margin="0,0,0,8" GroupName="SleepMode"/>
        <TextBlock Grid.Row="6" Text="恢复系统默认的休眠设置"
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,0,12"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="应用" Width="80" Height="32" Margin="0,0,10,0"
                    Click="btnApply_Click"
                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
            <Button Content="取消" Width="80" Height="32"
                    Click="btnCancel_Click"
                    Background="{StaticResource CardBackgroundBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
